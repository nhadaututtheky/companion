# Companion Server Configuration
# Copy this file to .env and fill in the values

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3579
NODE_ENV=development

# API key for authenticating requests (required in production)
API_KEY=your-secret-api-key-here

# ── License ──────────────────────────────────────────────────────────────────
# Companion license key (get from companion.theio.vn)
# Free tier (1 session) if not set
COMPANION_LICENSE_KEY=

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3580,http://localhost:3000

# ── Telegram ──────────────────────────────────────────────────────────────────
# Primary Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Comma-separated list of allowed Telegram chat IDs (leave empty to allow all)
TELEGRAM_ALLOWED_CHAT_IDS=

# Comma-separated list of admin Telegram user IDs (leave empty to allow all users)
# Get your ID: send /start to @userinfobot on Telegram
TELEGRAM_ALLOWED_USER_IDS=

# ── Domain / Reverse Proxy ────────────────────────────────────────────────────
# Option A: Cloudflare Tunnel (recommended — zero port expose, auto SSL)
#   1. cloudflared tunnel create companion
#   2. cloudflared tunnel route dns companion app.yourdomain.com
#   3. Set token below, uncomment cloudflared service in docker-compose.yml
CLOUDFLARE_TUNNEL_TOKEN=

# Option B: Nginx reverse proxy
#   See nginx/conf.d/companion.conf — replace domain, add SSL certs
#   Uncomment nginx service in docker-compose.yml

# ── Web UI ──────────────────────────────────────────────────────────────────
# API URL for the web frontend (defaults to http://localhost:3579)
# Set this if your server runs on a different host/port
# NEXT_PUBLIC_API_URL=http://localhost:3579

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite database path (relative to server package root)
DATABASE_PATH=./data/companion.db

# ── Logging ─────────────────────────────────────────────────────────────────
# Log level: debug, info, warn, error (default: info)
# LOG_LEVEL=info
