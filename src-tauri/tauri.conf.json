{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Companion",
  "identifier": "vn.theio.companion",
  "version": "0.5.0",
  "build": {
    "frontendDist": "http://localhost:3579",
    "devUrl": "http://localhost:3579",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Companion",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "visible": false,
        "decorations": true,
        "alwaysOnTop": false,
        "dragDropEnabled": false,
        "label": "main"
      }
    ],
    "trayIcon": {
      "iconPath": "icons/tray-icon.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false,
      "tooltip": "Companion"
    },
    "security": {
      "csp": "default-src 'self' http://localhost:3579 ws://localhost:3579; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-eval'",
      "dangerousDisableAssetCspModification": false,
      "freezePrototype": false
    }
  },
  "plugins": {
    "shell": {
      "open": false
    },
    "updater": {
      "pubkey": "",
      "endpoints": [
        "https://companion.theio.vn/updates/{{target}}/{{arch}}/{{current_version}}"
      ],
      "active": false
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": [
      "bun-server"
    ],
    "copyright": "© 2026 theio.vn",
    "category": "DeveloperTool",
    "shortDescription": "Multi-session Claude Code Manager",
    "longDescription": "Companion is a self-hosted desktop app for managing multiple Claude Code sessions with a unified dashboard.",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "nsis": {
        "installerIcon": "icons/installer.ico",
        "headerImage": "icons/installer-header.bmp",
        "sidebarImage": "icons/installer-sidebar.bmp",
        "installMode": "currentUser",
        "languages": ["English"]
      }
    },
    "macOS": {
      "frameworks": [],
      "exceptionDomain": "localhost",
      "signingIdentity": null,
      "entitlements": null,
      "minimumSystemVersion": "10.15"
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libappindicator3-1", "librsvg2-bin"]
      },
      "appimage": {
        "bundleMediaFramework": true
      },
      "rpm": {
        "depends": []
      }
    }
  }
}
