{
  "name": "companion",
  "private": true,
  "type": "module",
  "workspaces": ["packages/*"],
  "scripts": {
    "dev:server": "NODE_ENV=development bun run --hot packages/server/src/index.ts",
    "dev:web": "bun run --cwd packages/web dev",
    "build": "bun run --filter '*' build",
    "check": "bun run --filter '*' check && bun run check:settings",
    "check:settings": "bun run scripts/check-settings-consistency.ts",
    "lint": "eslint packages/",
    "lint:fix": "eslint packages/ --fix",
    "format": "prettier --write \"packages/**/*.{ts,tsx,json,css}\"",
    "format:check": "prettier --check \"packages/**/*.{ts,tsx,json,css}\"",
    "test": "bun run --filter '@companion/server' test",
    "db:generate": "bun run --filter '@companion/server' db:generate",
    "db:migrate": "bun run --filter '@companion/server' db:migrate",
    "db:studio": "bun run --filter '@companion/server' db:studio",
    "build:desktop": "bash scripts/build-desktop.sh",
    "build:desktop:debug": "bash scripts/build-desktop.sh --debug",
    "dev:desktop": "cd src-tauri && cargo tauri dev"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@next/eslint-plugin-next": "16.2.0",
    "eslint": "10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "sharp": "^0.34.5",
    "typescript": "^5.8.2",
    "typescript-eslint": "8.57.1"
  }
}
