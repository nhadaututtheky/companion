    "@hono/zod-validator": "^0.4.3",
    "drizzle-orm": "^0.39.3",
    "grammy": "^1.41.1",
    "hono": "^4.12.8",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.30.6"
  }
}
